# Copy this file to .env and fill in your values.
# The backend will auto-load .env on startup (via python-dotenv).

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to ./clawfans.db (SQLite) when not set.
# DATABASE_URL=sqlite:///./clawfans.db

# ── Ollama LLM ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Context window. Default 8192. The layered system prompt + chat history
# routinely exceeds 4096 (which silently truncates history). Raise if you
# have the VRAM; Qwen 2.5 supports up to 32768.
OLLAMA_NUM_CTX=8192

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Required for user-authenticated API calls. Get from clerk.com dashboard.
# For development you can leave these blank (auth will be skipped).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── Cloudflare R2 Image Storage (optional) ───────────────────────────────────
# If not set, images are served from local disk (backend/uploads/).
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=clawfans
R2_PUBLIC_URL=https://your-domain.dev

# ── Telegram Bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── ComfyUI local image generation (optional) ────────────────────────────────
COMFYUI_URL=http://127.0.0.1:8188

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
# Comma-separated list of browser origins allowed by CORS. Defaults to
# localhost dev origins when unset. Set this in production to your domain(s).
# ALLOWED_ORIGINS=https://clawfans.example.com,https://www.clawfans.example.com
