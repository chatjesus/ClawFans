# Backend production environment variables
# Place at: /opt/clawfans/backend/.env.production
# chmod 600 /opt/clawfans/backend/.env.production

# Clerk - backend secret key (get from clerk.com dashboard → API Keys)
# Switch to LIVE key when ready: sk_live_...
CLERK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_KEY

# Ollama (running locally on VPS)
OLLAMA_BASE_URL=http://localhost:11434

# Cloudflare R2 image storage
R2_ACCOUNT_ID=28c7a2284bad6930b719d160a5e692fa
R2_ACCESS_KEY=03dc8e5506b1e9394db2c8337eae0c44
R2_SECRET_KEY=9f877ba9e0aed2cf4ac67c2ded67e91b5f654a1ba5d5477e4471cd60c20abf27
R2_BUCKET=clawfans
R2_PUBLIC_URL=https://assets.tinyclaw.dev

# App
APP_ENV=production
LOG_LEVEL=info
