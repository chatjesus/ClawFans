# Backend production environment variables
# Place at: /opt/clawfans/backend/.env
# chmod 600 /opt/clawfans/backend/.env

# Clerk - backend secret key (get from clerk.com dashboard → API Keys)
CLERK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_KEY

# Ollama (running on same VPS)
OLLAMA_BASE_URL=http://localhost:11434

# Cloudflare R2 image storage
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=REPLACE_WITH_YOUR_ACCOUNT_ID
R2_ACCESS_KEY=REPLACE_WITH_YOUR_ACCESS_KEY_ID
R2_SECRET_KEY=REPLACE_WITH_YOUR_SECRET_ACCESS_KEY
R2_BUCKET=clawfans
R2_PUBLIC_URL=https://your-custom-domain.dev

# Database (defaults to ./clawfans.db if not set)
# DATABASE_URL=sqlite:////opt/clawfans/backend/clawfans.db

# Telegram Bot (optional)
# TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# App
APP_ENV=production
LOG_LEVEL=info
