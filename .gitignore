*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.env
venv/
*.db
*.db-journal
*.db-wal
*.db-shm

# Node / Next.js
node_modules/
.next/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Uploads (user-generated, not source code)
backend/uploads/avatars/
backend/uploads/refs/
backend/uploads/scenes/
backend/uploads/generated/
backend/uploads/manga/
backend/uploads/voice/
!backend/uploads/avatars/.gitkeep
!backend/uploads/refs/.gitkeep
!backend/uploads/scenes/.gitkeep

# Local TTS / test audio artifacts
backend/test_*.mp3
backend/*.mp3

# Image-editing scratch artifacts + resume logs
*_mask.png
scripts/*_resume.txt

# Credentials (NEVER commit)
credentials/
*.json.key
*.pem
backend/platform_config.json

# Env files with secrets (NEVER commit .env with real keys)
.env
.env.local
.env.production
.env.*.local
frontend/.env.local
frontend/.env.production
backend/.env

# Migration logs
scripts/r2_migrate_log.txt

# Logs
*.log
debug-*.log

# Generated avatars (large binary files)
frontend/public/avatars/*.png
!frontend/public/avatars/.gitkeep
